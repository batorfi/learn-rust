{
  "file_types": { "C++": ["metal"] },
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "inlayHints": {
          "maxLength": null,
          "lifetimeElisionHints": {
            "enable": "skip_trivial",
            "useParameterNames": true,
          },
          "closureReturnTypeHints": {
            "enable": "always",
          },
          "rust": {
            "analyzerTargetDir": true,
          },
        },
      },
      "enable_lsp_tasks": true,
    },
  },
}
